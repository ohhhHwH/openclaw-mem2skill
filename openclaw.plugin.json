{
  "id": "memory2skill",
  "name": "Memory to Skills",
  "description": "Captures user input, agent plans, and tool calls into structured logs, then extracts and generates reusable skills from conversation memory",
  "configSchema": {
    "type": "object",
    "properties": {
      "successThreshold": {
        "type": "number",
        "default": 0.8,
        "description": "技能升级阈值"
      },
      "shortMemoryThreshold": {
        "type": "number",
        "default": 3,
        "description": "短期记忆阈值"
      },
      "longMemoryThreshold": {
        "type": "number",
        "default": 10,
        "description": "长期记忆阈值"
      },
      "embeddingModel": {
        "type": "string",
        "default": "mock",
        "description": "嵌入模型"
      },
      "logDir": {
        "type": "string",
        "description": "插件日志目录（可选，默认 .openclaw/memory/plugin-logs/）"
      }
    }
  }
}
