r\n\r\n        var applyDarkstyle = ``;\r\n\r\n        // Light Color\r\n        var textColor = \"#000\";\r\n        var qRowBGColor = \"#fff\";\r\n        var qRowBorderColor = \"#fafafa\";\r\n        var qDiffBG = \"#f5f5f7\";\r\n\r\n        // Dark Style\r\n        var darkstyle = `\r\n                .question-list-base {\r\n                    /*background: rgba(0,0,0,0.02);*/\r\n                }\r\n            `;\r\n\r\n        if(window.location.href.includes(\"isDark=true\")) {\r\n            applyDarkstyle = darkstyle;\r\n            // Dark Color\r\n            textColor = \"#fff\";\r\n            qRowBGColor = \"#1b1b1d\";\r\n            qRowBorderColor = \"#232325\";\r\n            qDiffBG = \"#2d2d30\";\r\n        }\r\n\r\n\r\n        var appOnlyStyle = `\r\n            * {\r\n                -webkit-user-select: none;  \r\n                -moz-user-select: none;    \r\n                -ms-user-select: none;      \r\n                user-select: none;\r\n            }\r\n\r\n            .table-responsive.question-list-table {\r\n                overflow-x: hidden;\r\n            }\r\n\r\n            body, html {\r\n                background: ${qRowBGColor};\r\n            }\r\n            \r\n            .question-status-column,\r\n            #noj-navbar,\r\n            .category-group-base,\r\n            .assess-bar,\r\n            .question-filter-base,\r\n            .blog-sidebar,\r\n            #lc-footer,\r\n            hr.line.dotted.question-list-hr,\r\n            .reactable-pagination,\r\n            .reactable-th-frequency.reactable-header-sortable,\r\n            .frequency-column,\r\n            .reactable-th-status.reactable-header-sortable,\r\n            .tooltip.top.in,\r\n            .table-responsive.question-list-table thead,\r\n            .lock__13du {\r\n                display: none !important;\r\n            }\r\n            .question-disabled {\r\n                pointer-events: none;\r\n                position: relative;\r\n                opacity: 0.38;\r\n            }\r\n            .question-disabled::after {\r\n                content: \"\\\\f023\";\r\n                font: normal normal normal 14px/1 FontAwesome;\r\n                color: #ffa115;\r\n                font-size: 14px;\r\n                display: inline-block;\r\n                margin-left: 10px;\r\n            }\r\n            .blog-main,\r\n            .container {\r\n                width: 100%;\r\n            }\r\n            #base_content {\r\n                width: 100vw;\r\n            }\r\n            .content-wrapper,\r\n            .table-responsive.question-list-table {\r\n                padding-bottom: 0 !important;\r\n                margin-bottom: 0 !important;\r\n            }\r\n            table.table-striped {\r\n                margin-bottom: 0;\r\n            }\r\n            .reactable-th-question_id,\r\n            tbody.reactable-data tr > td:nth-child(2) {\r\n                \r\n            }\r\n            \r\n            /* tr row */\r\n            .question-list-table table tbody.reactable-data tr {\r\n                display: flex;\r\n                width: 100vw;\r\n                position: relative;\r\n                height: ${qRowHeight}px;\r\n                padding: ${qTBPadding}px ${qSidePadding}px;\r\n                background: ${qRowBGColor} !important;\r\n                border-top: 1px solid ${qRowBorderColor};\r\n            }\r\n            .question-list-table table tbody.reactable-data tr:hover {\r\n                background: ${qRowBGColor} !important;\r\n            }\r\n            tbody.reactable-data td {\r\n                \r\n            }\r\n\r\n            /* id */\r\n            tbody.reactable-data tr > td:nth-child(2) {\r\n                color: ${textColor};\r\n                padding-right: 0;\r\n                padding-left: 0;\r\n                font-weight: 500;\r\n                font-size: ${qTitleSize}px;\r\n                white-space: nowrap;\r\n            }\r\n            tbody.reactable-data tr > td:nth-child(2)::after {\r\n                content: \".\";\r\n                display: inline-block;\r\n            }\r\n            /* title */\r\n            tbody.reactable-data tr > td:nth-child(3) {\r\n                width: 100%;\r\n                font-weight: 500;\r\n                font-size: ${qTitleSize}px;\r\n            }\r\n            .question-list-table tbody .question-title {\r\n                overflow: initial;\r\n                max-width: none;\r\n            }\r\n            .question-list-table tbody .question-title a {\r\n                color: ${textColor};\r\n                display: block;\r\n                height: ${qRowHeight}px;\r\n                position: relative;\r\n                transform: translateY(-${qTBPadding + 8}px);\r\n                padding-top: ${qTBPadding + 8}px;\r\n                z-index: 1;\r\n            }\r\n\r\n            /* status */\r\n            .question-status-column {\r\n                /*\r\n                position: absolute;\r\n                bottom: ${qTBPadding}px;\r\n                left: ${qSidePadding}px;\r\n                */\r\n            }\r\n\r\n            /* solution */\r\n            tbody.reactable-data tr > td:nth-child(4) {\r\n                position: absolute;\r\n                bottom: ${qTBPadding}px;\r\n                left: ${qSidePadding}px;\r\n            }\r\n            a.solution-link {\r\n                font-size: ${qSubtitleSize}px;\r\n            }\r\n            a.solution-link::before {\r\n                content: \"题解${'\\\\00a0'}\";\r\n                display: inline-block;\r\n            }\r\n\r\n            /* acc */\r\n            tbody.reactable-data tr > td:nth-child(5) {\r\n                position: absolute;\r\n                bottom: ${qTBPadding}px;\r\n                right: ${qSidePadding}px;\r\n                font-size: ${qSubtitleSize}px;\r\n            }\r\n            tbody.reactable-data tr 